# =============================================
# Files NOT shipped to npm
# =============================================

# Source control
.git/
.gitignore
.gitattributes

# CI / release tooling
.github/
docs/
scripts/test-compile.mjs
scripts/install.sh
scripts/uninstall.sh
install.sh
uninstall.sh
CONTRIBUTING.md
CHANGELOG.md

# Tests
__tests__/
test/
*.test.js
*.test.mjs
*.spec.js
coverage/
.nyc_output/

# Local development
.dynamic-plan/
.cache/
.tmp/
tmp/

# Build artifacts (the compiler outputs these, don't ship them)
*.html
*.components.mjs

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Dependency directories
node_modules/
.pnp/
.pnp.js

# Environment
.env
.env.local
.env.*.local

# Lock files (npm-shrinkwrap.json IS shipped, but we use package-lock.json only for dev)
package-lock.json
yarn.lock
pnpm-lock.yaml
